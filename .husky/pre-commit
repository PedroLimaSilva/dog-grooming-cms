#!/usr/bin/env sh
set -e
ROOT="$(git rev-parse --show-toplevel 2>/dev/null)" || exit 1
cd "$ROOT"

# GUI git clients (e.g. Fork) often run hooks with a minimal PATH and no shell
# profile, so Yarn 1 / an old system Node can appear. Prefer the same Node as nvm.
export NVM_DIR="${NVM_DIR:-$HOME/.nvm}"
if [ -s "$NVM_DIR/nvm.sh" ]; then
  # shellcheck disable=SC1091
  . "$NVM_DIR/nvm.sh"
  if [ -f "$ROOT/.nvmrc" ]; then
    nvm use --silent 2>/dev/null || nvm use
  fi
elif command -v fnm >/dev/null 2>&1; then
  eval "$(fnm env --shell=sh 2>/dev/null)" || eval "$(fnm env 2>/dev/null)" || true
  (cd "$ROOT" && fnm use --install-if-missing 2>/dev/null) || (cd "$ROOT" && fnm use) || true
fi

NODE_MAJOR="$(node -p "Number(process.versions.node.split('.')[0])" 2>/dev/null || echo 0)"
if [ "$NODE_MAJOR" -lt 20 ]; then
  printf '%s\n' "husky/pre-commit: Node $(node -v 2>/dev/null || echo unknown) is too old; this repo needs Node >=20.19." >&2
  printf '%s\n' "Fork runs hooks without your login shell PATH. Fix: use Node 20+ on PATH for git, or run Fork from Terminal after \`nvm use\`, or set Fork's custom Git environment." >&2
  exit 1
fi

exec node "./node_modules/prettier/bin/prettier.cjs" --check .
